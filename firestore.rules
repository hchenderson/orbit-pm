rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function workspace(workspaceId) {
      return get(/databases/$(database)/documents/workspaces/$(workspaceId));
    }

    function membership(workspaceId) {
      return get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid));
    }

    function isMember(workspaceId) {
      return signedIn() && exists(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid));
    }

    function roleIs(workspaceId, roles) {
      return isMember(workspaceId) && membership(workspaceId).data.role in roles;
    }

    function canManage(workspaceId) {
      return roleIs(workspaceId, ['Owner', 'Admin']);
    }

    function canEdit(workspaceId) {
      return roleIs(workspaceId, ['Owner', 'Admin', 'Member']);
    }

    match /users/{userId} {
      allow create, read, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /workspaces/{workspaceId} {
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.workspaceName is string;
      allow read: if isMember(workspaceId);
      allow update: if canManage(workspaceId)
        && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if roleIs(workspaceId, ['Owner']);

      match /members/{memberId} {
        allow read: if isMember(workspaceId);
        allow create: if signedIn()
          && request.resource.data.id == memberId
          && request.resource.data.role in ['Owner', 'Admin', 'Member', 'Viewer']
          && (
            canManage(workspaceId)
            || (memberId == request.auth.uid && getAfter(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerId == request.auth.uid)
            || (
              memberId == request.auth.uid
              && request.resource.data.invitationId is string
              && request.auth.token.email is string
              && get(/databases/$(database)/documents/workspaces/$(workspaceId)/invitations/$(request.resource.data.invitationId)).data.status == 'pending'
              && get(/databases/$(database)/documents/workspaces/$(workspaceId)/invitations/$(request.resource.data.invitationId)).data.email == request.auth.token.email
              && request.resource.data.role == get(/databases/$(database)/documents/workspaces/$(workspaceId)/invitations/$(request.resource.data.invitationId)).data.role
            )
          );
        allow update: if (
            canManage(workspaceId)
            && request.resource.data.id == resource.data.id
            && request.resource.data.role in ['Owner', 'Admin', 'Member', 'Viewer']
          ) || (
            signedIn()
            && memberId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['preferences'])
          );
        allow delete: if canManage(workspaceId)
          && memberId != workspace(workspaceId).data.ownerId;
      }

      match /projects/{projectId} {
        allow read: if isMember(workspaceId);
        allow create, update: if canEdit(workspaceId)
          && request.resource.data.id == projectId
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0;
        allow delete: if canManage(workspaceId);
      }

      match /tasks/{taskId} {
        allow read: if isMember(workspaceId);
        allow create, update: if canEdit(workspaceId)
          && request.resource.data.id == taskId
          && request.resource.data.projectId is string
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0;
        allow delete: if canEdit(workspaceId);
      }

      match /notifications/{notificationId} {
        allow read: if isMember(workspaceId)
          && resource.data.recipientId == request.auth.uid;
        allow create: if canManage(workspaceId)
          || (isMember(workspaceId) && request.resource.data.recipientId == request.auth.uid);
        allow update, delete: if isMember(workspaceId)
          && resource.data.recipientId == request.auth.uid
          && request.resource.data.recipientId == resource.data.recipientId;
      }

      match /invitations/{invitationId} {
        allow create, delete: if canManage(workspaceId);
        allow read: if canManage(workspaceId)
          || (signedIn() && request.auth.token.email is string && resource.data.email == request.auth.token.email);
        allow update: if canManage(workspaceId)
          || (
            signedIn()
            && request.auth.token.email is string
            && resource.data.email == request.auth.token.email
            && resource.data.status == 'pending'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'acceptedAt', 'acceptedBy'])
            && request.resource.data.status == 'accepted'
            && request.resource.data.acceptedBy == request.auth.uid
          );
      }
    }

    match /mail/{mailId} {
      allow create: if signedIn()
        && request.resource.data.invitationWorkspaceId is string
        && canManage(request.resource.data.invitationWorkspaceId)
        && request.resource.data.to is list
        && request.resource.data.to.size() == 1
        && request.resource.data.template.name == 'workspace-invitation';
      allow read, update, delete: if false;
    }
  }
}
