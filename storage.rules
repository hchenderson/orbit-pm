rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function member(workspaceId) {
      return firestore.get(/databases/(default)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid));
    }

    function isMember(workspaceId) {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid));
    }

    function canEdit(workspaceId) {
      return isMember(workspaceId)
        && member(workspaceId).data.role in ['Owner', 'Admin', 'Member'];
    }

    match /workspaces/{workspaceId}/tasks/{taskId}/{attachmentId}/{fileName} {
      allow read: if isMember(workspaceId);
      allow create, update: if canEdit(workspaceId)
        && request.resource.size < 20 * 1024 * 1024;
      allow delete: if canEdit(workspaceId);
    }
  }
}
